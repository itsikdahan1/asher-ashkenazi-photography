rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /siteContent/main {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email in [
          'asher7676@gmail.com',
          'itsikdahan1@gmail.com'
        ];
    }
  }
}
